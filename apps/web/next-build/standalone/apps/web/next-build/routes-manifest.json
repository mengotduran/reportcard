{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/uploads/:path*",
        "destination": "/uploads/:path*",
        "regex": "^/uploads(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      }
    ],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/print/class/[classLevel]",
      "regex": "^/print/class/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPclassLevel": "nxtPclassLevel"
      },
      "namedRegex": "^/print/class/(?<nxtPclassLevel>[^/]+?)(?:/)?$"
    },
    {
      "page": "/report-cards/class/[classLevel]",
      "regex": "^/report\\-cards/class/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPclassLevel": "nxtPclassLevel"
      },
      "namedRegex": "^/report\\-cards/class/(?<nxtPclassLevel>[^/]+?)(?:/)?$"
    },
    {
      "page": "/report-cards/class/[classLevel]/[subjectId]",
      "regex": "^/report\\-cards/class/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPclassLevel": "nxtPclassLevel",
        "nxtPsubjectId": "nxtPsubjectId"
      },
      "namedRegex": "^/report\\-cards/class/(?<nxtPclassLevel>[^/]+?)/(?<nxtPsubjectId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/report-cards/transcript/[studentId]",
      "regex": "^/report\\-cards/transcript/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPstudentId": "nxtPstudentId"
      },
      "namedRegex": "^/report\\-cards/transcript/(?<nxtPstudentId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/report-cards/[id]",
      "regex": "^/report\\-cards/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/report\\-cards/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/superadmin/schools/[id]",
      "regex": "^/superadmin/schools/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/superadmin/schools/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
