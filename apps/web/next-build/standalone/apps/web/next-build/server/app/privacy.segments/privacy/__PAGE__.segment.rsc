6:["$","section",null,{"className":"space-y-3","children":[["$","h2",null,{"className":"text-lg font-bold text-foreground","children":"AI-generated remarks"}],["$","div",null,{"className":"space-y-3 text-sm leading-relaxed text-muted-foreground","children":["$","p",null,{"children":"If a school enables AI-assisted remarks, a student's name and term average are sent to a third-party AI provider (Google's Gemini API) to generate a short written comment. No other student data — marks per subject, guardian details, fee records, or birth details — is sent as part of this feature. Staff can review and edit any AI-generated remark before it is published."}]}]]}]
7:["$","section",null,{"className":"space-y-3","children":[["$","h2",null,{"className":"text-lg font-bold text-foreground","children":"How we use this information"}],["$","div",null,{"className":"space-y-3 text-sm leading-relaxed text-muted-foreground","children":[["$","ul",null,{"className":"list-disc pl-5 space-y-1.5","children":[["$","li",null,{"children":"To operate the platform: authenticate accounts, generate report cards and transcripts, and track fee payments."}],["$","li",null,{"children":"To let schools communicate academic results to students and guardians."}],["$","li",null,{"children":"To maintain security, prevent abuse, and troubleshoot technical issues."}]]}],["$","p",null,{"children":"We do not sell any data, and we do not use it for advertising. Bulletin has no ads and no third-party analytics or tracking SDKs."}]]}]]}]
8:["$","section",null,{"className":"space-y-3","children":[["$","h2",null,{"className":"text-lg font-bold text-foreground","children":"Who we share data with"}],["$","div",null,{"className":"space-y-3 text-sm leading-relaxed text-muted-foreground","children":[["$","p",null,{"children":"Data is only shared with the infrastructure providers that host and run Bulletin, strictly to operate the service:"}],["$","ul",null,{"className":"list-disc pl-5 space-y-1.5","children":[["$","li",null,{"children":[["$","strong",null,{"className":"text-foreground","children":"Neon"}]," — database hosting."]}],["$","li",null,{"children":[["$","strong",null,{"className":"text-foreground","children":"Railway"}]," — API server hosting."]}],["$","li",null,{"children":[["$","strong",null,{"className":"text-foreground","children":"Vercel"}]," — web application hosting."]}],["$","li",null,{"children":[["$","strong",null,{"className":"text-foreground","children":"Google (Gemini API)"}]," — only when a school enables AI remarks, and only the student's name and average as described above."]}]]}],["$","p",null,{"children":"These providers process data on our behalf under their own security and confidentiality terms. We do not share data with advertisers or data brokers."}]]}]]}]
9:["$","section",null,{"className":"space-y-3","children":[["$","h2",null,{"className":"text-lg font-bold text-foreground","children":"Data retention and deletion"}],["$","div",null,{"className":"space-y-3 text-sm leading-relaxed text-muted-foreground","children":["$","p",null,{"children":"Data is retained for as long as the school's account is active, so that historical academic records remain available. A school administrator can deactivate or remove a student or staff record at any time. To request deletion of a specific account or dataset, contact us at the email below — we will act on the request or route it to the responsible school if the school controls that data."}]}]]}]
a:["$","section",null,{"className":"space-y-3","children":[["$","h2",null,{"className":"text-lg font-bold text-foreground","children":"Data security"}],["$","div",null,{"className":"space-y-3 text-sm leading-relaxed text-muted-foreground","children":["$","p",null,{"children":"Passwords are stored using industry-standard one-way hashing (bcrypt) and are never visible to Bulletin staff. Access to student and academic data is restricted by role — for example, a subject teacher can only see the classes and subjects assigned to them."}]}]]}]
b:["$","section",null,{"className":"space-y-3","children":[["$","h2",null,{"className":"text-lg font-bold text-foreground","children":"Children's data"}],["$","div",null,{"className":"space-y-3 text-sm leading-relaxed text-muted-foreground","children":["$","p",null,{"children":"Some users of Bulletin are school-age children. Student accounts are created and managed by schools, not by children signing up on their own, and Bulletin does not knowingly collect data directly from children outside of that school-managed context. Parents or guardians with questions about a specific student's data should contact their school, or reach us directly at the email below."}]}]]}]
