generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ParentSchool {
  id        String   @id @default(uuid())
  name      String
  city      String?
  country   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  sections  School[]
}

model School {
  id                 String              @id @default(uuid())
  name               String
  type               SchoolType
  email              String              @unique
  phone              String?
  address            String?
  website            String?
  logo               String?
  subdomain          String              @unique
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  coverImage         String?
  parentSchoolId     String?
  language           String              @default("EN")
  coverImages        String[]            @default([])
  acronym            String?
  batch              Int?
  repeatThreshold    Float?
  authorizationNumber String?
  // Official-header letterhead text (left/right blocks in the "Official"
  // report-card header style), set once here so it stays consistent no
  // matter how many report-card templates/layouts render it. One EN and one
  // FR variant per side; the header auto-picks the one matching `language`.
  officialLeftTextEn  String?
  officialLeftTextFr  String?
  officialRightTextEn String?
  officialRightTextFr String?
  classLevels        ClassLevel[]
  departments        Department[]
  classListTemplate  ClassListTemplate?
  excelTemplates     ExcelTemplate[]
  feePayments              FeePayment[]
  hndRegistrationPayments  HndRegistrationPayment[]
  gradingScale             GradingScale?
  reportCards        ReportCard[]
  reportCardTemplate ReportCardTemplate?
  parentSchool       ParentSchool?       @relation(fields: [parentSchoolId], references: [id])
  students           Student[]
  subjects           Subject[]
  terms              Term[]
  users              User[]
}

model GradingScale {
  id        String   @id @default(uuid())
  schoolId  String   @unique
  ranges    Json     @default("[]")
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])
}

model ReportCardTemplate {
  id        String   @id @default(uuid())
  schoolId  String   @unique
  config    Json     @default("{}")
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])
}

model ClassListTemplate {
  id        String   @id @default(uuid())
  schoolId  String   @unique
  config    Json     @default("{}")
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])
}

model Department {
  id        String       @id @default(uuid())
  schoolId  String
  name      String
  order     Int          @default(0)
  isDefault Boolean      @default(false)
  createdAt DateTime     @default(now())
  school    School       @relation(fields: [schoolId], references: [id])
  classes   ClassLevel[]

  @@unique([schoolId, name])
}

model ClassLevel {
  id           String   @id @default(uuid())
  schoolId     String
  name         String
  abbreviation String?
  hasStream    Boolean  @default(false)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  feeAmount            Int      @default(0)
  maxScore             Int      @default(20)
  hndRegistrationFee   Int?
  departmentId         String?
  department           Department? @relation(fields: [departmentId], references: [id])
  school               School   @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, name])
}

model User {
  id                String           @id @default(uuid())
  schoolId          String?
  name              String
  email             String           @unique
  password          String
  role              UserRole
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  masterClassLevel  String?
  preferredLanguage String           @default("EN")
  reportCards      ReportCard[]
  teacherSubjects  TeacherSubject[]
  school           School?          @relation(fields: [schoolId], references: [id])
}

model Student {
  id            String        @id @default(uuid())
  schoolId      String
  name          String
  studentId     String
  classLevel    String
  guardianName  String?
  guardianPhone String?
  guardianEmail String?
  isActive            Boolean       @default(true)
  directLevel2Entry   Boolean       @default(false)
  isRepeatingLevel    Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  gender              String?
  status              StudentStatus @default(ACTIVE)
  feePayments              FeePayment[]
  hndRegistrationPayments  HndRegistrationPayment[]
  reportCards              ReportCard[]
  school                   School        @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, studentId])
}

model FeePayment {
  id         String   @id @default(uuid())
  schoolId   String
  studentId  String
  session    String
  amount     Int
  paidOn     DateTime
  note       String?
  recordedBy String?
  createdAt  DateTime @default(now())
  school     School   @relation(fields: [schoolId], references: [id])
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, session])
}

model HndRegistrationPayment {
  id         String   @id @default(uuid())
  schoolId   String
  studentId  String
  session    String
  amount     Int
  paidOn     DateTime
  note       String?
  recordedBy String?
  createdAt  DateTime @default(now())
  school     School   @relation(fields: [schoolId], references: [id])
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, session])
}

model Subject {
  id              String           @id @default(uuid())
  schoolId        String
  name            String
  code            String?
  classLevel      String
  createdAt       DateTime         @default(now())
  maxScore        Int              @default(20)
  coefficient     Int              @default(1)
  compulsory      Boolean          @default(true)
  credit          Int?
  term            String?
  reportEntries   ReportEntry[]
  school          School           @relation(fields: [schoolId], references: [id])
  teacherSubjects TeacherSubject[]
}

model TeacherSubject {
  id        String   @id @default(uuid())
  userId    String
  subjectId String
  createdAt DateTime @default(now())
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
}

model Term {
  id          String       @id @default(uuid())
  schoolId    String
  name        String
  session     String
  startDate   DateTime
  endDate     DateTime
  isCurrent       Boolean      @default(false)
  printingEnabled Boolean      @default(true)
  createdAt       DateTime     @default(now())
  reportCards     ReportCard[]
  school          School       @relation(fields: [schoolId], references: [id])
}

model ReportCard {
  id                   String        @id @default(uuid())
  studentId            String
  schoolId             String
  termId               String
  createdById          String
  status               ReportStatus  @default(DRAFT)
  totalScore           Float?
  average              Float?
  position             Int?
  remarks              String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  marksEditGrantedTo   String?
  remarksEditGrantedTo String?
  remarksFr            String?
  remarksAiEn          String?
  remarksAiFr          String?
  remarksSource        String?
  decision             String?
  createdBy            User          @relation(fields: [createdById], references: [id])
  school               School        @relation(fields: [schoolId], references: [id])
  student              Student       @relation(fields: [studentId], references: [id])
  term                 Term          @relation(fields: [termId], references: [id])
  entries              ReportEntry[]

  @@unique([studentId, termId])
}

model ReportEntry {
  id           String     @id @default(uuid())
  reportCardId String
  subjectId    String
  score        Float?
  grade        String?
  remarks      String?
  seq1Score    Float?
  seq2Score    Float?
  resitScore   Float?     // university only: exam mark re-obtained after resitting a failed course; seq2Score is kept as the original attempt
  reportCard   ReportCard @relation(fields: [reportCardId], references: [id])
  subject      Subject    @relation(fields: [subjectId], references: [id])
}

model ExcelTemplate {
  id          String   @id @default(uuid())
  schoolId    String
  name        String
  fileData    Bytes
  classLevels String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School   @relation(fields: [schoolId], references: [id])
}

enum SchoolType {
  PRIMARY
  SECONDARY
  UNIVERSITY
}

enum UserRole {
  SUPERADMIN
  SCHOOL_ADMIN
  VICE_PRINCIPAL
  CLASS_TEACHER
  SUBJECT_TEACHER
  STUDENT
  PARENT
  CLASS_MASTER
}

enum ReportStatus {
  DRAFT
  PUBLISHED
}

enum StudentStatus {
  ACTIVE
  DISABLED
  DISMISSED
}
