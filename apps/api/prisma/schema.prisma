generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ParentSchool {
  id        String   @id @default(uuid())
  name      String
  city      String?
  country   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  sections  School[]
}

model School {
  id                 String              @id @default(uuid())
  name               String
  type               SchoolType
  email              String              @unique
  phone              String?
  address            String?
  website            String?
  logo               String?
  // Defaults to TEACHERS, so existing schools keep behaving exactly as they did.
  marksEntryMode     MarksEntryMode      @default(TEACHERS)
  marksEntryChanges  MarksEntryModeChange[]
  // Official stamp/seal image. Prints on OFFICIAL copies only, via a `stamp` section
  // the admin places on the report card or transcript. Separate from `logo`: the logo
  // is the letterhead mark on every copy, the stamp is what makes a copy official.
  stamp              String?
  subdomain          String              @unique
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  coverImage         String?
  parentSchoolId     String?
  language           String              @default("EN")
  coverImages        String[]            @default([])
  acronym            String?
  batch              Int?
  repeatThreshold    Float?
  authorizationNumber String?
  // Official-header letterhead text (left/right blocks in the "Official"
  // report-card header style), set once here so it stays consistent no
  // matter how many report-card templates/layouts render it. One EN and one
  // FR variant per side; the header auto-picks the one matching `language`.
  officialLeftTextEn  String?
  officialLeftTextFr  String?
  officialRightTextEn String?
  officialRightTextFr String?
  classLevels        ClassLevel[]
  departments        Department[]
  classListTemplate  ClassListTemplate?
  excelTemplates     ExcelTemplate[]
  feePayments              FeePayment[]
  hndRegistrationPayments  HndRegistrationPayment[]
  gradingScale             GradingScale?
  reportCards        ReportCard[]
  reportCardTemplate ReportCardTemplate?
  parentSchool       ParentSchool?       @relation(fields: [parentSchoolId], references: [id])
  students           Student[]
  subjects           Subject[]
  terms              Term[]
  users              User[]
}

model GradingScale {
  id        String   @id @default(uuid())
  schoolId  String   @unique
  ranges    Json     @default("[]")
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])
}

model ReportCardTemplate {
  id        String   @id @default(uuid())
  schoolId  String   @unique
  config    Json     @default("{}")
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])
}

model ClassListTemplate {
  id        String   @id @default(uuid())
  schoolId  String   @unique
  config    Json     @default("{}")
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])
}

model Department {
  id        String       @id @default(uuid())
  schoolId  String
  name      String
  order     Int          @default(0)
  isDefault Boolean      @default(false)
  createdAt DateTime     @default(now())
  school    School       @relation(fields: [schoolId], references: [id])
  classes   ClassLevel[]

  @@unique([schoolId, name])
}

model ClassLevel {
  id           String   @id @default(uuid())
  schoolId     String
  name         String
  abbreviation String?
  hasStream    Boolean  @default(false)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  feeAmount            Int      @default(0)
  maxScore             Int      @default(20)
  hndRegistrationFee   Int?
  departmentId         String?
  department           Department? @relation(fields: [departmentId], references: [id])
  school               School   @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, name])
}

model User {
  id                String           @id @default(uuid())
  schoolId          String?
  name              String
  email             String           @unique
  password          String
  role              UserRole
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  masterClassLevel  String?
  preferredLanguage String           @default("EN")
  // Departments (secondary) / programmes (university) this teacher is explicitly
  // placed in — independent of which subjects they're assigned, so a newly added
  // teacher shows under a department immediately rather than only after their first
  // subject assignment. Plain strings, not a relation: universities have no real
  // Department row at all (see department.controller.ts), department there is only
  // a name embedded in class names, so a uniform string list works for both types.
  // A teacher can be in more than one at once.
  departments       String[]         @default([])
  // Self-service "forgot password" flow — cloud only (the offline SQLite build has no
  // email delivery, so its route is stubbed out entirely; see
  // scripts/offline-build/stubs/passwordReset.routes.stub.ts). Deliberately NOT mirrored
  // to prisma/sqlite/schema.prisma: no offline code path ever reads or writes these, so
  // there is nothing to keep in sync there. Stores a SHA-256 hash of the emailed token,
  // never the raw token itself.
  resetTokenHash      String?   @unique
  resetTokenExpiresAt DateTime?
  // University semester a teacher was created under, while they have zero course
  // assignments — lets getTeachers show a brand-new teacher only in the semester
  // tab they were added under (not every tab) even before they're assigned a real
  // course. Ignored the moment they have ANY TeacherSubject; assigning them a
  // course in a different semester IS how an admin "transfers" them there — no
  // separate transfer action. Not university-specific in the schema (harmless
  // null elsewhere), mirrored to prisma/sqlite/schema.prisma since this bug and
  // fix apply to both builds equally.
  createdForTerm      String?
  // Set the first time a teacher actually completes the set-password flow (see
  // passwordReset.controller.ts resetPassword). Null means an online-invited
  // teacher has never set a password yet — used to show a "Pending Setup" badge
  // in getTeachers (shared code, both builds). Offline-created teachers get this
  // stamped immediately at creation, since the admin hands them a working
  // password directly there — always non-null offline, so pendingSetup is
  // always false there. Mirrored to prisma/sqlite/schema.prisma for that reason.
  passwordSetAt       DateTime?
  reportCards      ReportCard[]
  teacherSubjects  TeacherSubject[]
  school           School?          @relation(fields: [schoolId], references: [id])
}

model Student {
  id            String        @id @default(uuid())
  schoolId      String
  name          String
  studentId     String
  classLevel    String
  guardianName  String?
  guardianPhone String?
  guardianEmail String?
  isActive            Boolean       @default(true)
  directLevel2Entry   Boolean       @default(false)
  isRepeatingLevel    Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  gender              String?
  // Birth details. Optional everywhere: a student registered without them simply prints
  // a blank row. Stored as "YYYY-MM-DD" TEXT rather than a DateTime on purpose — a birth
  // date is a calendar date with no time or zone, and round-tripping it through a
  // timestamp shifts it by a day for anyone west of UTC.
  dateOfBirth         String?
  placeOfBirth        String?
  status              StudentStatus @default(ACTIVE)
  feePayments              FeePayment[]
  hndRegistrationPayments  HndRegistrationPayment[]
  reportCards              ReportCard[]
  school                   School        @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, studentId])
}

model FeePayment {
  id         String   @id @default(uuid())
  schoolId   String
  studentId  String
  session    String
  amount     Int
  paidOn     DateTime
  note       String?
  recordedBy String?
  createdAt  DateTime @default(now())
  school     School   @relation(fields: [schoolId], references: [id])
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, session])
}

model HndRegistrationPayment {
  id         String   @id @default(uuid())
  schoolId   String
  studentId  String
  session    String
  amount     Int
  paidOn     DateTime
  note       String?
  recordedBy String?
  createdAt  DateTime @default(now())
  school     School   @relation(fields: [schoolId], references: [id])
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, session])
}

model Subject {
  id              String           @id @default(uuid())
  schoolId        String
  name            String
  code            String?
  classLevel      String
  createdAt       DateTime         @default(now())
  maxScore        Int              @default(20)
  coefficient     Int              @default(1)
  compulsory      Boolean          @default(true)
  credit          Int?
  term            String?
  reportEntries   ReportEntry[]
  school          School           @relation(fields: [schoolId], references: [id])
  teacherSubjects TeacherSubject[]
}

model TeacherSubject {
  id        String   @id @default(uuid())
  userId    String
  subjectId String
  createdAt DateTime @default(now())
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
}

model Term {
  id          String       @id @default(uuid())
  schoolId    String
  name        String
  session     String
  startDate   DateTime
  endDate     DateTime
  isCurrent       Boolean      @default(false)
  printingEnabled Boolean      @default(true)
  createdAt       DateTime     @default(now())
  reportCards     ReportCard[]
  school          School       @relation(fields: [schoolId], references: [id])
}

model ReportCard {
  id                   String        @id @default(uuid())
  studentId            String
  schoolId             String
  termId               String
  createdById          String
  status               ReportStatus  @default(DRAFT)
  totalScore           Float?
  average              Float?
  position             Int?
  remarks              String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  marksEditGrantedTo   String?
  remarksEditGrantedTo String?
  remarksFr            String?
  remarksAiEn          String?
  remarksAiFr          String?
  remarksSource        String?
  decision             String?
  createdBy            User          @relation(fields: [createdById], references: [id])
  school               School        @relation(fields: [schoolId], references: [id])
  student              Student       @relation(fields: [studentId], references: [id])
  term                 Term          @relation(fields: [termId], references: [id])
  entries              ReportEntry[]

  @@unique([studentId, termId])
}

model ReportEntry {
  id           String     @id @default(uuid())
  reportCardId String
  subjectId    String
  score        Float?
  grade        String?
  remarks      String?
  seq1Score    Float?
  seq2Score    Float?
  resitScore   Float?     // university only: exam mark re-obtained after resitting a failed course; seq2Score is kept as the original attempt
  reportCard   ReportCard @relation(fields: [reportCardId], references: [id])
  subject      Subject    @relation(fields: [subjectId], references: [id])
}

model ExcelTemplate {
  id          String   @id @default(uuid())
  schoolId    String
  name        String
  fileData    Bytes
  classLevels String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School   @relation(fields: [schoolId], references: [id])
}

enum SchoolType {
  PRIMARY
  SECONDARY
  UNIVERSITY
}

enum UserRole {
  SUPERADMIN
  SCHOOL_ADMIN
  VICE_PRINCIPAL
  CLASS_TEACHER
  SUBJECT_TEACHER
  STUDENT
  PARENT
  CLASS_MASTER
}

enum ReportStatus {
  DRAFT
  PUBLISHED
}

enum StudentStatus {
  ACTIVE
  DISABLED
  DISMISSED
}

/**
 * Who records marks at a school.
 *
 * TEACHERS   - the default and how every school worked before this existed.
 * ADMIN_ONLY - only SCHOOL_ADMIN/VICE_PRINCIPAL may save marks. Some universities keep
 *              marks out of teachers' hands entirely to remove the opportunity to cheat.
 *              Teachers still SEE the grid, read-only, so they can check their subject.
 *
 * An enum rather than a boolean: the obvious next mode is "teachers keep CA, admin owns
 * the exam", which a boolean could not grow into.
 */
enum MarksEntryMode {
  TEACHERS
  ADMIN_ONLY
}

/**
 * Every switch of who records marks, kept forever.
 *
 * A log, NOT a "changedBy/changedAt" pair on School: switching to TEACHERS and back would
 * overwrite itself and leave only the innocent-looking final state, hiding exactly the
 * window this exists to reveal. Two flips must leave two rows.
 *
 * This does not PREVENT a switch, and cannot: an admin can already enter and change any
 * mark directly. What it removes is the ability to do it quietly.
 *
 * `changedByName` is a snapshot, not a join: an audit record must still read the same
 * after the user is renamed or deleted.
 */
model MarksEntryModeChange {
  id            String         @id @default(uuid())
  schoolId      String
  mode          MarksEntryMode
  changedById   String?
  changedByName String
  changedAt     DateTime       @default(now())
  /// The semester this switch happened in, so the "twice per semester" cap counts rows
  /// rather than doing date arithmetic. Null when no semester was running: between
  /// academic years there is nothing to count against, and switching is unrestricted.
  termId        String?
  /// A switch made BY the provider (superadmin) on the school's behalf. Never counts
  /// against the school's two, because it IS the permission that lifts the cap.
  byProvider    Boolean        @default(false)
  school        School         @relation(fields: [schoolId], references: [id])

  @@index([schoolId, changedAt])
  @@index([schoolId, termId])
}
