# Copy to .env and fill in. Values here are placeholders.

DATABASE_URL=postgresql://user:password@localhost:5432/reportcard_db
JWT_SECRET=change_me
SUPERADMIN_SECRET=change_me
# PORT is injected by the host (Railway). Locally defaults to 5000.
# PORT=5000

# --- AI-assisted report-card remarks (optional) ---
# Leave GEMINI_API_KEY empty to disable AI and use the built-in bilingual
# band-based fallback remarks (report generation is never blocked).
# Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# A current Flash-Lite model has the highest free-tier daily cap. Swappable.
GEMINI_MODEL=gemini-2.5-flash-lite

# Provider is pluggable via an OpenAI-compatible endpoint. Default targets
# Gemini. To switch to Groq / Mistral / OpenRouter, set these instead:
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_API_KEY=your_provider_key
# AI_MODEL=llama-3.3-70b-versatile

# --- Password reset emails (optional, cloud only) ---
# Leave empty to disable email sending — reset links log to the server
# console instead (fine for local dev). Sent via Resend against the verified
# usebulletin.org domain: https://resend.com/api-keys
RESEND_API_KEY=
# Where the emailed reset link points — the deployed web app's URL in production.
FRONTEND_URL=http://localhost:3000
