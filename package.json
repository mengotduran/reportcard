{
  "name": "reportcard-app",
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "mobile": "npm run dev --workspace apps/mobile",
    "mobile:clean": "npm run dev --workspace apps/mobile -- -c"
  },
  "devDependencies": {
    "turbo": "latest"
  }
}
